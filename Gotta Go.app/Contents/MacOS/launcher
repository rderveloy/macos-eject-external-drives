#!/bin/bash
SELF="$0"
hops=0
while [ -L "$SELF" ]; do
    SELF=$(readlink "$SELF")
    hops=$((hops + 1))
    if [ "$hops" -ge 40 ]; then
        osascript -e 'display alert "Gotta Go" message "Could not resolve app bundle path (circular symlink detected)." as critical'
        exit 1
    fi
done
SELF_DIR=$(cd "$(dirname "$SELF")" && pwd)
SCRIPT=$(cd "$SELF_DIR/../Resources" && pwd)/gotta-go.command

if [ ! -f "$SCRIPT" ]; then
    osascript -e 'display alert "Gotta Go" message "Could not locate gotta-go.command inside the app bundle." as critical'
    exit 1
fi

# Pass $SCRIPT as an argument so AppleScript's quoted form of handles any
# special characters in the install path (e.g. single quotes, spaces).
osascript - "$SCRIPT" <<'APPLESCRIPT'
on run argv
    set scriptPath to item 1 of argv
    tell application "Terminal"
        activate
        do script "exec " & quoted form of scriptPath
    end tell
end run
APPLESCRIPT
